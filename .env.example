# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database ─────────────────────────────────────────────────
POSTGRES_USER=openmusic
POSTGRES_PASSWORD=openmusic_secret
POSTGRES_DB=open_music
DATABASE_URL="postgresql://openmusic:openmusic_secret@localhost:5432/open_music?schema=public"

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── MinIO / S3 ───────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_BUCKET=open-music-cache

# ─── Music Providers ──────────────────────────────────────────
# YouTube Data API v3 (optional — used for metadata enrichment)
YOUTUBE_API_KEY=

# Jamendo API
JAMENDO_CLIENT_ID=

# yt-dlp binary path (defaults to system PATH)
YTDLP_PATH=yt-dlp

# Cache audio TTL (seconds, default 7 days)
CACHE_AUDIO_TTL=604800

# ─── Rate limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
